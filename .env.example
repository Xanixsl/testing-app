# =====================================================================
# ШАБЛОН для .env. Скопируй в .env и заполни своими значениями.
# .env НИКОГДА не должен попадать в git.
# =====================================================================

# --- БД (для sprinthost MySQL — выдаются в Панели управления → MySQL)
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASSWORD=

# --- Секрет cookie Flask
# python -c "import secrets; print(secrets.token_hex(32))"
VELORA_SECRET_KEY=

# --- Мастер-ключ для шифрования секретов в БД (Fernet, 32 байта в base64)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VELORA_FERNET_KEY=

# --- Соль для fingerprint-хеша на welcome
VELORA_PREVIEW_FP_SALT=

# --- Telegram-бот
VELORA_TG_BOT_TOKEN=
VELORA_TG_BOT_USERNAME=
VELORA_TG_ADMIN_IDS=

# --- OAuth Google
VELORA_OAUTH_GOOGLE_CLIENT_ID=
VELORA_OAUTH_GOOGLE_CLIENT_SECRET=

# --- Базовый URL сайта (https://example.com)
VELORA_SITE_URL=

# --- Локальная разработка: 1=SQLite, 0=MySQL, auto=авто
# VELORA_SQLITE=auto

